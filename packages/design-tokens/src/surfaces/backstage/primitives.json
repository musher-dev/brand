{
  "$schema": "https://json.schemastore.org/design-tokens",
  "$description": "Backstage-only primitives - a slate + amber accent palette that visually distinguishes the internal operator tool from product surfaces. Included only in the backstage build.",
  "color": {
    "$type": "color",
    "internal": {
      "$description": "Internal-tool accent palette (Backstage)",
      "slate-900": {
        "$value": "oklch(22% 0.02 255)",
        "$description": "Backstage base canvas (dark) - cool slate"
      },
      "slate-800": {
        "$value": "oklch(28% 0.02 255)",
        "$description": "Backstage elevated surface (dark)"
      },
      "slate-100": {
        "$value": "oklch(93% 0.01 255)",
        "$description": "Backstage elevated surface (light)"
      },
      "slate-50": {
        "$value": "oklch(96% 0.01 255)",
        "$description": "Backstage base canvas (light) - subtle cool tint"
      },
      "amber": {
        "$value": "oklch(75% 0.15 75)",
        "$description": "Backstage brand accent - amber, signals internal context"
      },
      "amber-hover": {
        "$value": "oklch(68% 0.15 75)",
        "$description": "Backstage brand accent hover"
      }
    }
  }
}
