{
  "$schema": "https://json.schemastore.org/design-tokens",
  "opacity": {
    "$type": "number",
    "$description": "Opacity scale for disabled, muted, and interaction-state surfaces",
    "disabled": {
      "$value": 0.4,
      "$description": "Disabled controls and text"
    },
    "muted": {
      "$value": 0.5,
      "$description": "De-emphasized / secondary content"
    },
    "hover": {
      "$value": 0.2,
      "$description": "Hover overlay strength"
    },
    "active": {
      "$value": 0.3,
      "$description": "Active/pressed overlay strength"
    },
    "scrim": {
      "$value": 0.6,
      "$description": "Backdrop scrim over base surface (modals, drawers)"
    }
  }
}
