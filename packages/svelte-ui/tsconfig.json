{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": ["src/lib/**/*.ts", "src/lib/**/*.svelte"],
  "exclude": ["dist", "node_modules", "src/stories"]
}
