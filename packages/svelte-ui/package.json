{
  "name": "@musher-dev/svelte-ui",
  "version": "0.0.0",
  "description": "Musher shared Svelte component library, themed by @musher-dev/design-tokens",
  "type": "module",
  "license": "MIT",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-package && publint",
    "prepublishOnly": "svelte-package",
    "dev": "storybook dev -p 6006 --no-open --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "stylelint \"src/**/*.svelte\"",
    "publint": "publint",
    "clean": "rm -rf dist storybook-static"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@musher-dev/design-tokens": "^2.4.2"
  },
  "devDependencies": {
    "@musher-dev/design-tokens": "workspace:*",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/svelte": "^8.4.0",
    "@storybook/svelte-vite": "^8.4.0",
    "postcss-html": "^1.7.0",
    "publint": "^0.3.0",
    "storybook": "^8.4.0",
    "stylelint": "^16.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/musher-dev/brand.git",
    "directory": "packages/svelte-ui"
  },
  "publishConfig": {
    "access": "public"
  }
}
